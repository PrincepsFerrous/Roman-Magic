{
  "grant-origin-noble": {
    "name": "grant-origin-noble",
    "conditions": [
      {
        "type": "story",
        "query": "player is a young scion of one of the Twelve High Houses during the Ludi Corvini, chosen to represent their family at the Grand Games and protect a family secret"
      },
      {
        "type": "party-location",
        "operator": "equals",
        "value": "The Palatine"
      }
    ],
    "effects": [
      {
        "type": "player-traits",
        "operator": "add",
        "value": "Patrician Scion"
      }
    ]
  },
  "grant-origin-collegium": {
